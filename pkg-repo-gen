#!/usr/bin/env python3
"""
pkg-repo-gen - Generate repository index for pkg packages
"""

import argparse
import json
import hashlib
import tarfile
import sys
from pathlib import Path
from typing import Dict

def read_metadata_from_pkg(pkg_file: Path) -> Dict:
    """Extract metadata from a .pkg file"""
    metadata = {}
    
    try:
        with tarfile.open(pkg_file, 'r:*') as tar:
            # Extract metadata files
            for member in tar.getmembers():
                if member.name.startswith('metadata/'):
                    meta_name = member.name.split('/', 1)[1]
                    
                    if meta_name in ['name', 'version', 'author', 'license', 'depends', 'description']:
                        try:
                            f = tar.extractfile(member)
                            if f:
                                content = f.read().decode('utf-8').strip()
                                metadata[meta_name] = content
                        except:
                            pass
    except Exception as e:
        print(f"Error reading {pkg_file}: {e}", file=sys.stderr)
        return None
    
    return metadata

def calculate_checksums(file_path: Path) -> Dict[str, str]:
    """Calculate checksums for a file"""
    checksums = {}
    
    # MD5
    md5 = hashlib.md5()
    # SHA256
    sha256 = hashlib.sha256()
    
    with open(file_path, 'rb') as f:
        while chunk := f.read(8192):
            md5.update(chunk)
            sha256.update(chunk)
    
    checksums['md5'] = md5.hexdigest()
    checksums['sha256'] = sha256.hexdigest()
    
    return checksums

def generate_index(repo_dir: Path, output_file: Path):
    """Generate repository index from .pkg files"""
    
    if not repo_dir.exists():
        print(f"Error: Repository directory {repo_dir} does not exist")
        return False
    
    index = {
        'version': 1,
        'packages': {}
    }
    
    # Find all .pkg files
    pkg_files = list(repo_dir.glob('*.pkg'))
    
    if not pkg_files:
        print(f"Warning: No .pkg files found in {repo_dir}")
    
    print(f"Processing {len(pkg_files)} package(s)...")
    
    for pkg_file in pkg_files:
        print(f"  Processing {pkg_file.name}...")
        
        # Read metadata
        metadata = read_metadata_from_pkg(pkg_file)
        if not metadata:
            print(f"    Warning: Could not read metadata, skipping")
            continue
        
        pkg_name = metadata.get('name')
        if not pkg_name:
            print(f"    Warning: No package name found, skipping")
            continue
        
        # Calculate checksums
        checksums = calculate_checksums(pkg_file)
        
        # Get file size
        size = pkg_file.stat().st_size
        
        # Build package entry
        pkg_entry = {
            'version': metadata.get('version', 'unknown'),
            'filename': pkg_file.name,
            'size': size,
            'md5sum': checksums['md5'],
            'sha256sum': checksums['sha256']
        }
        
        # Add optional fields
        if 'author' in metadata:
            pkg_entry['author'] = metadata['author']
        if 'license' in metadata:
            pkg_entry['license'] = metadata['license']
        if 'depends' in metadata:
            pkg_entry['depends'] = metadata['depends']
        if 'description' in metadata:
            pkg_entry['description'] = metadata['description']
        
        index['packages'][pkg_name] = pkg_entry
        print(f"    Added {pkg_name} {pkg_entry['version']}")
    
    # Write index
    with open(output_file, 'w') as f:
        json.dump(index, f, indent=2)
    
    print(f"\nRepository index generated: {output_file}")
    print(f"Total packages: {len(index['packages'])}")
    
    return True

def main():
    parser = argparse.ArgumentParser(
        description="Generate repository index for pkg packages"
    )
    
    parser.add_argument('repo_dir', type=Path,
                       help='Directory containing .pkg files')
    parser.add_argument('-o', '--output', type=Path, default=Path('index.json'),
                       help='Output index file (default: index.json)')
    
    args = parser.parse_args()
    
    success = generate_index(args.repo_dir, args.output)
    return 0 if success else 1

if __name__ == '__main__':
    sys.exit(main())
